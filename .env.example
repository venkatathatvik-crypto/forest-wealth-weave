# Frontend public env (Vite). Copy to `.env` and adjust.
# Only VITE_-prefixed vars are exposed to the browser — never put secrets here.

# Base URL of the Spring Boot backend, including its context-path (/gold-emi-api).
# Backend default: http://localhost:8080/gold-emi-api
VITE_API_BASE_URL=http://localhost:8080/gold-emi-api

# NOTE: the Vite dev server ALSO defaults to port 8080 (see vite.config.ts),
# which collides with the backend. Run the frontend on a different port, e.g.:
#   npx vite dev --port 5173
# (CORS on the backend already allows http://localhost:5173 and :3000.)
