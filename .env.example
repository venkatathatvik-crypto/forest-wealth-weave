# Frontend public env (Vite). Only VITE_-prefixed vars reach the browser —
# never put secrets here. NOTE: Vite bakes these in at BUILD time, not runtime.
#
# You normally don't need a plain `.env` — Vite auto-loads per build mode:
#   - `.env.development`  → used by `vite dev`   (committed: localhost backend)
#   - `.env.production`   → used by `vite build` (committed: relative /gold-emi-api)
#
# This .example documents the variable; override per-mode files only if needed.

# Base URL of the backend API.
#   Dev   (cross-origin): http://localhost:8080/gold-emi-api
#   Prod  (same-origin via Nginx): /gold-emi-api   ← relative, domain-agnostic
VITE_API_BASE_URL=http://localhost:8080/gold-emi-api

# Vite dev server port (vite.config.ts sets 5173). Run: npm run dev
# Backend runs on 8080 with context-path /gold-emi-api.
