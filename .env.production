# Loaded by Vite in production builds (`vite build`). In production the frontend
# (PM2) and backend WAR are served behind the SAME Nginx domain, so the API is
# reached via a SAME-ORIGIN RELATIVE path — no host/port, no hardcoded domain,
# no CORS needed. Nginx routes /gold-emi-api to the backend (Tomcat :8080).
#
# Because it's relative, this value is domain-agnostic: changing the domain or
# renewing the Let's Encrypt cert needs NO rebuild.
VITE_API_BASE_URL=/gold-emi-api
